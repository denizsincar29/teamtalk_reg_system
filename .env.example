# TeamTalk Registration System Configuration
# Copy this file to .env and fill in your values

# TeamTalk Server Configuration
TEAMTALK_HOST=denizsincar.ru
TEAMTALK_TCP_PORT=10333
TEAMTALK_UDP_PORT=10333
TEAMTALK_USERNAME=bot
TEAMTALK_PASSWORD=your_password_here

# Web Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# Proxy Configuration (for Apache/Nginx reverse proxy)
FORWARDED_ALLOW_IPS=*
