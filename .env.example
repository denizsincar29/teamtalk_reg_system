# TeamTalk Registration System Configuration
# Created by Deniz Sincar (denizsincar.ru)
# Copy this file to .env and fill in your values

# TeamTalk Server Configuration
TEAMTALK_HOST=your-teamtalk-server.com
TEAMTALK_TCP_PORT=10333
TEAMTALK_UDP_PORT=10333
TEAMTALK_USERNAME=bot
TEAMTALK_PASSWORD=your_password_here

# Bot nickname (display name shown to other users on the server)
# If not set, defaults to the username
TEAMTALK_NICKNAME=Registration Bot

# Bot Connection Configuration
# Set to true if the bot should connect to localhost instead of TEAMTALK_HOST
# This is useful when running the web app on the same machine as the TeamTalk server
# The .tt files will still use TEAMTALK_HOST for end users to connect
USE_LOCALHOST_FOR_BOT=false

# Web Server Configuration
APP_HOST=0.0.0.0
APP_PORT=8000

# Proxy Configuration (for Apache/Nginx reverse proxy)
FORWARDED_ALLOW_IPS=*

# Root path for reverse proxy with subpath (e.g., "/myapp" if proxied at example.com/myapp)
# Leave empty if not using a subpath
ROOT_PATH=
